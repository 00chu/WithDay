# 백엔드 API 서버 주소
# 로컬 개발 예시: http://localhost:8080/api
# 배포 환경 예시: https://배포도메인.com/api
VITE_BACKSERVER=

# Google OAuth 클라이언트 ID
# Google Cloud Console에서 발급받은 Web Client ID 입력
# 예시: 1234567890-abcdefg.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=

# OneSignal App ID
# OneSignal 대시보드의 App ID 입력
VITE_ONESIGNAL_APP_ID=
