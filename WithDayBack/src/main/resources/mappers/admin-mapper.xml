<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.test.withdayback.admin.dao.AdminDao">
    <select id="selectAllMember" resultType="User">
        SELECT profile_image, nickname, email, provider, gender, birthday, status, created_at
        FROM user

        <where>
            <!-- 닉네임 / 이메일 검색 -->
            <if test="keyword != null and keyword != ''">
                <!-- 하나의 조건으로 묶기 위해 괄호로 묶음 -->
                (
                <!-- MyBatis가 문자열 안 #{} 를 제대로 처리 못함 -->
                nickname like concat('%', #{keyword}, '%')   <!-- => '%keyword%' -->
                or email like concat('%', #{keyword}, '%')
                )
            </if>
            <!-- 성별 조건 있을 때 성별 조건 -->
            <if test="gender != null and gender != ''">
                and gender = #{gender}
            </if>
            <!-- 가입경로 provider -->
            <if test="provider != null and provider != ''">
                and provider = #{provider}
            </if>
            <!-- 회원 상태 status -->
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
        </where>

        <choose>
            <!-- 기본 정렬 -->
            <otherwise>
                ORDER BY id DESC
            </otherwise>
        </choose>

        limit #{offset}, #{size}
    </select>

    <select id="selectMemberCount"
            parameterType="com.test.withdayback.admin.dto.AdminMemberRequest"
            resultType="int">

        SELECT count(*)
        FROM user

        <where>
            <if test="keyword != null and keyword != ''">
                (
                nickname LIKE CONCAT('%', #{keyword}, '%')
                OR email LIKE CONCAT('%', #{keyword}, '%')
                )
            </if>

            <if test="gender != null and gender != ''">
                AND gender = #{gender}
            </if>

            <if test="provider != null and provider != ''">
                AND provider = #{provider}
            </if>

            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>

    </select>
</mapper>