<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.test.withdayback.admin.dao.AdminDao">
    <select id="selectAllMember" resultType="User">
        SELECT profile_image, nickname, email, provider, gender, birthday, status, create_at
        FROM user

        <where>
            <!-- 성별 조건 있을 때 성별 조건 -->
            <if test="gender != null and gender != ''">
                gender = #{gender}
            </if>
            <!-- 가입경로 provider -->
            <if test="provider != null">
                and provider = #{provider}
            </if>
            <!-- 회원 상태 status -->
            <if test="status != null">
                and status = #{status}
            </if>
        </where>

        <choose>
            <!-- 닉네임 오름차순 -->
            <when test="sort == 'nicknameAsc'">
                ORDER BY nickname ASC
            </when>

            <!-- 닉네임 내림차순 -->
            <when test="sort == 'nicknameDesc'">
                ORDER BY nickname DESC
            </when>

            <!-- 이메일 오름차순 -->
            <when test="sort == 'emailAsc'">
                ORDER BY email ASC
            </when>

            <!-- 이메일 내림차순 -->
            <when test="sort == 'emailDesc'">
                ORDER BY email DESC
            </when>

            <!-- 기본 정렬 -->
            <otherwise>
                ORDER BY id DESC
            </otherwise>
        </choose>
    </select>
</mapper>